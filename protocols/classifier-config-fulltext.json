{
  "version": "1.1-fulltext",
  "default_decision": "Include",
  "default_justification": "Sem assinatura de exclusão clara; revisar full-text manualmente para confirmar Include.",
  "proximity_window": 400,
  "priority_order": [
    "H_llm_supports_other_method",
    "D_devops_or_logs_not_rm",
    "E_strict_telecom",
    "C_llm_as_workload",
    "F_out_of_scope_domain",
    "A_classical_rl_marl_no_llm",
    "B_classical_mas_no_llm",
    "mas_llm_based",
    "agent_llm_based",
    "llm_agentic_ai_generic"
  ],
  "categories": [
    {
      "id": "H_llm_supports_other_method",
      "label": "LLM apenas dá suporte a outro método",
      "kind": "exclude",
      "justification": "O LLM aparece em papel de suporte (gera heurísticas, embeddings, features ou recompensas para RL/MARL/otimização clássica). Não há loop agentic AI dirigindo decisão de RM.",
      "priority_index": 0,
      "patterns": [
        {
          "id": "llm_explicit_support_role",
          "regex": "\\b(?:llms?|large\\s+language\\s+models?|gpts?|llama|foundation\\s+models?)\\b[^.]{0,300}\\b(?:guides?|provides?\\s+heuristics?|generates?\\s+heuristics?|augments?|enhances?|enriches?|assists?|aids?|supplements?|complements?|informs?)\\b[^.]{0,200}\\b(?:rl|marl|reinforcement\\s+learning|q[-\\s]?learning|sarsa|dqn|ppo|a3c|ddpg|ga\\b|genetic\\s+algorithm|metaheuristic|ant\\s+colony|particle\\s+swarm|simulated\\s+annealing|tabu|ilp|milp|optimization\\s+(?:algorithm|method|model)|heuristic\\s+search|moga|nsga|pso|aco|sa\\b)\\b",
          "description": "LLM explicitly in support role for non-LLM optimization/RL method"
        },
        {
          "id": "llm_as_feature_extractor",
          "regex": "\\b(?:llm|large\\s+language\\s+model|gpt|bert|transformer)\\b[^.]{0,200}\\b(?:embedding|feature\\s+extract|state\\s+representation|reward\\s+(?:shap|design)|input\\s+to\\s+(?:the\\s+)?(?:rl|drl|marl|q[-\\s]?learning|policy|critic|actor)|generates?\\s+features?)\\b",
          "description": "LLM used purely to produce embeddings/features/rewards consumed by RL/optimization"
        },
        {
          "id": "hybrid_llm_rl_llm_subordinate",
          "regex": "\\b(?:llm[-\\s]?(?:guided|aided|assisted|augmented|enhanced|empowered|enriched)|llm[-\\s]?(?:sarsa|dqn|ppo|q[-\\s]?learning|marl|drl)|(?:rl|marl|drl)[-\\s]?with[-\\s]?llm)\\b",
          "description": "Hyphenated combos that signal LLM is subordinate component of an RL/optimization pipeline"
        }
      ],
      "overrides": []
    },
    {
      "id": "D_devops_or_logs_not_rm",
      "label": "DevOps/logs/incidents (não RM)",
      "kind": "exclude",
      "justification": "Tarefa de DevOps/observabilidade (incident triage, RCA, geração de manifestos) — não é decisão de resource management.",
      "priority_index": 1,
      "patterns": [
        {
          "id": "devops_logs_incidents",
          "regex": "\\b(?:incident\\s+(?:triage|management|response|resolution)|root[-\\s]cause\\s+analysis|\\brca\\b|log\\s+(?:analysis|summariz|parsing|anomaly)|alert\\s+(?:correlation|noise|fatigue|clustering)|alarm\\s+(?:correlation|management)|runbook\\s+(?:generation|automation)|postmortem|on[-\\s]?call|chatops|aiops|sre\\s+assistant|fault\\s+(?:diagnosis|localization)|troubleshoot)\\b",
          "description": "DevOps / observability / incident-management tasks (not RM decisions)"
        },
        {
          "id": "deployment_assistant_no_rm",
          "regex": "\\b(?:deployment\\s+(?:assistant|automation|chatbot|copilot)|infrastructure[-\\s]as[-\\s]code\\s+(?:generation|assistant)|terraform\\s+(?:generation|assistant)|ansible\\s+(?:assistant|generation)|kubernetes\\s+(?:manifest|yaml)\\s+(?:generation|assistant)|configuration\\s+(?:assistant|generation|recommendation))\\b",
          "description": "DevOps deployment assistance (config/IaC generation) without RM decision loop"
        }
      ],
      "overrides": []
    },
    {
      "id": "E_strict_telecom",
      "label": "Estritamente telecom/5G/6G",
      "kind": "exclude",
      "justification": "Problema estritamente de RAN/5G/6G/spectrum sem substrato cloud/edge RM.",
      "priority_index": 2,
      "patterns": [
        {
          "id": "strict_telecom_only",
          "regex": "\\b(?:5g|6g|ran|o[-\\s]?ran|c[-\\s]?ran|v[-\\s]?ran|new\\s+radio|nr\\b|gnodeb|gnb|enb|enodeb|sub[-\\s]?6\\s?ghz|mmwave|beamform|massive\\s+mimo|hetnet|small\\s+cell|macro\\s+cell|network\\s+slic|ran\\s+slic|spectrum\\s+(?:allocation|sharing)|fronthaul|backhaul|midhaul|baseband\\s+unit|bbu|core\\s+network|epc\\b|5gc\\b|amf\\b|smf\\b|upf\\b|pdcp|rrc|mac\\s+layer|phy\\s+layer|physical\\s+layer|csi\\s+feedback|channel\\s+estimation|interference\\s+management|handover|qos\\s+slic)\\b(?:[^.]{0,500}\\b(?:5g|6g|ran|slic|spectrum|beamform|fronthaul|backhaul)\\b){2,}",
          "description": "Strictly RAN/5G/6G/spectrum problems with no cloud/edge RM substrate"
        }
      ],
      "overrides": []
    },
    {
      "id": "C_llm_as_workload",
      "label": "LLM como workload (servir/treinar), não como agente",
      "kind": "exclude",
      "justification": "LLM as workload",
      "priority_index": 3,
      "patterns": [
        {
          "id": "wl_train_llm_a",
          "regex": "\\b(?:training|fine[-\\s]?tuning|pre[-\\s]?training)\\b[^.,]{0,200}\\b(?:llms?|foundation\\s+models?|large\\s+language\\s+models?|large\\s+models?|transformer[-\\s]based)\\b",
          "description": "training/fine-tuning + LLM"
        },
        {
          "id": "wl_train_llm_b",
          "regex": "\\b(?:llms?|foundation\\s+models?|large\\s+language\\s+models?|large\\s+models?|transformer[-\\s]based)\\b[^.,]{0,200}\\b(?:training|fine[-\\s]?tuning|pre[-\\s]?training)\\b",
          "description": "LLM + training/fine-tuning"
        },
        {
          "id": "wl_train_cluster",
          "regex": "\\b(?:ai|ml)\\s+training\\s+(?:cluster|workload)\\b",
          "description": "AI/ML training cluster"
        },
        {
          "id": "wl_training_workload",
          "regex": "\\btraining\\s+(?:cluster|workload)s?\\b",
          "description": "training cluster/workload"
        },
        {
          "id": "wl_customizing_transformer",
          "regex": "\\bcustomizing\\s+(?:transformer|llm|foundation\\s+model)",
          "description": "customizing transformer/LLM"
        },
        {
          "id": "wl_distributed_finetuning",
          "regex": "\\b(?:decentralized|distributed|federated|split)\\s+(?:fine[-\\s]?tuning|training)\\s+(?:of\\s+)?(?:foundation\\s+models?|large\\s+language|llms?)",
          "description": "distributed fine-tuning of LLMs"
        },
        {
          "id": "wl_inference_llm_a",
          "regex": "\\b(?:llm|llms|gpt|generative\\s+ai|genai|aigc|large\\s+language\\s+model|large\\s+language|foundation\\s+model|transformer)[s]?\\b[^.,]{0,200}\\b(?:inference|serving|deploy(?:ment|ing)?|accelerat|batching|quantization|pruning|decoding|hot[-\\s]swap|disaggregat)\\b",
          "description": "LLM + inference/serving"
        },
        {
          "id": "wl_inference_llm_b",
          "regex": "\\b(?:inference|serving|deploy(?:ment|ing)?|accelerat|batching|quantization|pruning|decoding|hot[-\\s]swap|disaggregat)\\b[^.,]{0,200}\\b(?:llms?|gpts?|generative\\s+ai|genai|aigc|large\\s+language\\s+models?|foundation\\s+models?|transformers?)\\b",
          "description": "inference/serving + LLM"
        },
        {
          "id": "wl_abs_serving_llms",
          "regex": "\\b(?:serving|serve|deploying|deploy|hosting|host)\\s+(?:of\\s+)?(?:llms?|large\\s+language\\s+models?|foundation\\s+models?|generative\\s+ai)",
          "description": "serving/deploying LLMs"
        },
        {
          "id": "wl_abs_llm_infra",
          "regex": "\\b(?:llm|large\\s+language\\s+model|foundation\\s+model)\\s+(?:inference\\s+)?(?:engine|system|platform|infrastructure|stack|pipeline)",
          "description": "LLM inference engine/infra"
        },
        {
          "id": "wl_abs_for_llm_workload",
          "regex": "\\bfor\\s+(?:efficient\\s+|scalable\\s+)?(?:llm|large\\s+language\\s+model|foundation\\s+model)\\s+(?:inference|serving|training|fine[\\s-]?tuning|deployment)",
          "description": "for LLM inference/serving (workload)"
        },
        {
          "id": "wl_abs_we_propose_llm_serving",
          "regex": "\\bwe\\s+(?:propose|present|introduce|design)\\s+(?:a\\s+)?(?:novel\\s+|new\\s+)?(?:framework|system|method|approach|scheme|technique|architecture)\\s+(?:for|to)\\s+(?:efficient\\s+|scalable\\s+)?(?:serving|inference|deploy(?:ing|ment)|train(?:ing)|fine[\\s-]?tuning)\\s+(?:of\\s+)?(?:llms?|large\\s+language\\s+models?|foundation\\s+models?|generative\\s+ai)",
          "description": "we propose system for LLM serving (workload)"
        }
      ],
      "overrides": [
        {
          "id": "ovr_with_llm",
          "regex": "\\bwith\\s+(?:llms?|large\\s+language\\s+models?|generative\\s+ai|genai)\\b",
